{
  "name": "particle",
  "version": "1.0.0",
  "description": "Source build tooling for rahulkar.com (Jekyll portfolio)",
  "private": true,
  "author": "Rahul Kar",
  "license": "ISC",
  "scripts": {
    "build:css": "sass src/styles/main.scss assets/css/main.css --style=compressed --no-source-map",
    "build:js": "esbuild src/js/app.js --minify --outfile=assets/js/main.js",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "sass --watch src/styles/main.scss:assets/css/main.css --style=compressed --no-source-map",
    "watch:js": "esbuild src/js/app.js --minify --outfile=assets/js/main.js --watch",
    "serve": "bundle exec jekyll serve --livereload",
    "dev": "npm run build && concurrently -k -n css,js,jekyll \"npm:watch:css\" \"npm:watch:js\" \"npm:serve\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "sass": "^1.83.4"
  }
}
